---
import Layout from '../layouts/Layout.astro';
import Topbar from '../components/topbar.astro';

import IconImage from '../components/icon-image.astro';
import LabelTitle from '../components/label-title.astro';
import LinkPreviewBox from '../components/link-preview-box.astro';
import { Code } from 'astro-expressive-code/components';

import Footer from '../components/footer.astro'

const ogUrl = new URL(Astro.url.pathname, Astro.site).href;
---

<Layout pageTitle="About" ogUrl={ogUrl} ogDescription="自己紹介">
	<Topbar />
  <div class="container">

    <IconImage
      imageSrc="/images/icon.avif"
      size={320}
    />

    <div class="content">
      <LabelTitle text = "よく使うアカウント名" />
      <div class="category-text">
        こいらっく、ココネ
      </div>

      <LabelTitle text = "アカウント" />
      <div class="category-text">
        <div class="links-box">
          <LinkPreviewBox
            title="GitHub"
            description="最近はTauriとかが好き"
            url="https://github.com/coiluck/"
          />
          <LinkPreviewBox
            title="Twitter"
            description="Xではありません"
            url="https://twitter.com/RabbitGbf"
          />
          <LinkPreviewBox
            title="chichi-pui"
            description="AIイラスト1"
            url="https://www.chichi-pui.com/users/coiluck/"
          />
          <LinkPreviewBox
            title="Aipictors"
            description="AIイラスト2"
            url="https://www.aipictors.com/users/6f92b753-d44f-dd7d-6c98-3bb495495278/"
          />
          <LinkPreviewBox
            title="pixiv"
            description="更新しない。ナゾノクサの絵ばかり"
            url="https://www.pixiv.net/users/63923759"
          />
          <LinkPreviewBox
            title="Truth Social"
            description="二日で飽きた"
            url="https://truthsocial.com/@coiluck"
          />
          <LinkPreviewBox
            title="Steam"
            description="遊ぶ"
            url="https://steamcommunity.com/id/coiluck/"
          />
          <LinkPreviewBox
            title="YouTube"
            description="限定公開で動画を共有する時に使う"
            url="https://www.youtube.com/@kozakurakokone"
          />
          <LinkPreviewBox
            title="Misskey"
            description="予備"
            url="https://misskey.io/@Asiraat/"
          />
          <LinkPreviewBox
            title="mixi2"
            description="予備"
            url="https://mixi.social/@coiluck"
          />
        </div>
      </div>

      <LabelTitle text = "Love" />
      <div class="category-text">
        <LabelTitle text = "Novel" isChild = true />
        <div class="category-text">
          ハヤカワ文庫JAなどを好む。<br>
          &nbsp;&nbsp;・プロジェクトぴあの<br>
          &nbsp;&nbsp;・同志少女よ、敵を撃て<br>
          &nbsp;&nbsp;・ツインスターサイクロンランナウェイ<br>
          &nbsp;&nbsp;・虐殺器官<br>
          その他<br>
          &nbsp;&nbsp;・妹さえいればいい<br>
          &nbsp;&nbsp;・蝶と帝国<br>
        </div>
        <LabelTitle text = "Web Novel" isChild = true />
        <div class="category-text">
          小説家になろうをメインで読んでいる。稀にカクヨムやハーメルンには足を延ばす。<br>
        </div>
        <LabelTitle text = "Comic" isChild = true />
        <div class="category-text">
          マンガを読むことはあまりないけど。<br>
          &nbsp;&nbsp;・ゆゆ式<br>
          &nbsp;&nbsp;・ゆるゆり<br>
          &nbsp;&nbsp;・児玉まりあ文学集成<br>
        </div>
        <LabelTitle text = "Music" isChild = true />
        <div class="category-text">
          &nbsp;&nbsp;・マイナーで静かなボカロ<br>
          &nbsp;&nbsp;・作詞作曲が麻枝准かユリイカノンのもの<br>
          &nbsp;&nbsp;・音ゲーの曲<br>
          &nbsp;&nbsp;・Nightcore<br>
          <br>
          これとか、<br>
          <LinkPreviewBox
            title="ボカロ - 静"
            description="playlist · coiluck · 34 items"
            url="https://youtube.com/playlist?list=PL3MPhEsfgh10a-2zYMJOdA0BCmPeFo5b0&si=GW4LjLQDJ_akc_0Q"
          />
          これなど。
          <LinkPreviewBox
            title="ピアノ"
            description="playlist · coiluck · 73 items"
            url="https://youtube.com/playlist?list=PL3MPhEsfgh10TkA8w41sGFC1ChFhrP7hQ&si=09uIqqL8Mvq2zFb7"
          />
        </div>

        <LabelTitle text = "Game" isChild = true />
        <div class="category-text">今プレイしているもの: Delta Force（PC版）<br>
          過去には<br>
          &nbsp;&nbsp;・グランブルーファンタジー<br>
          &nbsp;&nbsp;・アークナイツ<br>
          &nbsp;&nbsp;・ヘブンバーンズレッド<br>
          &nbsp;&nbsp;・Hoi4<br>
          などをやっていた。
        </div>

        <LabelTitle text = "Other" isChild = true />
        <div class="category-text">
          好きな色: <span style="color: #ff7f7e;">#FF7F7E</span><br>
          好きなこと: ゲームを作ること<br>
        </div>
      </div>

      <LabelTitle text = "感謝" />
      <div class="category-text">
        <div class="category-text-table">
          <div class="category-text-table-item">
            <span><a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a></span>
            <span>これで作っている</span>
          </div>
          <div class="category-text-table-item">
            <span>GitHub Pages</span>
            <span>ホストしてくれている</span>
          </div>
          <div class="category-text-table-item">
            <span><a href="https://github.com/3846masa/kauntah-svg" target="_blank" rel="noopener noreferrer">kauntah-svg</a></span>
            <span>かわいいアクセスカウンタ</span>
          </div>
          <div class="category-text-table-item">
            <span>Me</span>
            <span>つくったので</span>
          </div>
        </div>
      </div>

      <LabelTitle text = "サイトバナー" />
      <div class="category-text">
          <img src="/images/banner.png" alt="サイトバナー" width="200" class="free">
          <p>持ち帰り・直リンクご自由にどうぞ。使用時は以下のように:</p>
          <Code code={`<a href="https://coiluck.moe/" target="_blank" rel="noopener noreferrer"><img src="https://coiluck.moe/images/banner.png" width="200" alt="革命学舎 | coiluckのwebサイト"></a>`} lang="html" />
          <p>相互リンクをしたい方はお問い合わせください</p>
      </div>
    </div>
    <Footer />
  </div>
  <style>
    .container {
      display: flex;
      flex-direction: column;
      align-items: center;
      height: 100dvh;
      margin: 0 auto;
      padding-top: 90px;
      overflow-y: auto;
      scrollbar-width: none;
      &::-webkit-scrollbar {
        display: none;
      }
    }
    @media (hover: hover) {
      .container {
        height: auto; /* 100dvhだと下部にスペースができちゃう */
      }
    }
    .title {
      width: 70%;
      font-size: 1.3rem;
      font-weight: bold;
      margin: 0 auto;
    }
    .content {
      flex: 1;
      width: 70%;
      margin: 0 auto;
      margin-bottom: 1rem;
    }
    .category-text {
      width: calc(100% - 2rem);
      margin-left: 2rem;
      font-size: 1rem;
    }
    .links-box {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 10px 20px;
      z-index: 2;
    }
    @media (max-width: 767px) {
      .title, .content {
        width: 80%;
      }
    }
    @media (max-width: 480px) {
      .title, .content {
        width: 90%;
      }
    }

    .category-text-table {
      display: grid;
      grid-template-columns: auto 1fr;
      row-gap: .5rem;
    }
    .category-text-table-item {
      grid-column: 1 / -1;
      display: grid;
      grid-template-columns: subgrid;
    }

    .category-text-table-item span {
      border-bottom: 1px solid var(--text);
      padding: 0.4rem 0;
    }

    .category-text-table-item span:last-child {
      padding-left: 1rem;
    }
    .category-text-table-item span a {
      color: var(--link);
    }
  </style>
</Layout>