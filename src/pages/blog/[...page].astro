---
import type { GetStaticPathsOptions } from 'astro';
import { getSortedPosts } from '../../utils/getPosts';
import Layout from '../../layouts/Layout.astro';
import Topbar from '../../components/topbar.astro';
import BlogImage from '../../components/blog-image.astro';
import BlogLine from '../../components/blog-line.astro';
import Search from "../../components/Search.astro";
import BlogPostCard from '../../components/blog-post-card.astro';
import Pagination from '../../components/pagination.astro';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const allSortedPosts = await getSortedPosts();

  // ページネーション実行
  const paginatedResult = paginate(allSortedPosts, { pageSize: 5 });
  return paginatedResult;
}

import type { BlogPostWithExcerpt } from '../../utils/type';
import type { Page } from 'astro';

interface Props {
  page: Page<BlogPostWithExcerpt>;
}
const { page } = Astro.props;

// OGP用
const ogDescription = "書く、これしか出来ないから";
const ogUrl = new URL(Astro.url.pathname, Astro.site).toString();

// 記事データ用
import getPostMetadata from '../../utils/postMetadata'
---
<Layout
  pageTitle="Blog"
  ogDescription={ogDescription}
  ogUrl={ogUrl}
>
  <Topbar />
  <div class="blog-header">
    <BlogImage />
    <Search />
  </div>
  <main>
    <div class="blog-content">
      {page && page.data ? (
        <>
        {page.data.map((post, index) => {
          const { title, date, tags, slug, excerpt } = getPostMetadata(post);

          return (
            <BlogPostCard
              slug={slug}
              title={title}
              tags={tags}
              date={date}
              excerpt={excerpt}
              index={index}
            />
          );
        })}
      </>
      ) : (
        <div style="text-align: center; padding: 2rem;">
          <p>現在、表示できる投稿がありません</p>
        </div>
      )}
    </div>

    <BlogLine
      pcSize={70}
      smSize={90}
      isNeedMargin={false}
    />

    <Pagination page={page} />
  </main>
</Layout>

<style>
  .blog-header {
    padding-top: 8rem;
  }
  @media (max-width: 767px) {
    .blog-header {
      padding-top: 6rem;
    }
  }
  main {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .blog-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin: 0 auto;
    width: 70%;
  }
  @media (max-width: 767px) {
    .blog-content {
      width: 90%;
    }
  }
</style>