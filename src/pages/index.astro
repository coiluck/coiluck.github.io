---
import Layout from '../layouts/Layout.astro';
import Topbar from '../components/topbar.astro';
import IconImage from '../components/icon-image.astro';
import Image from 'astro/components/Image.astro'
import backIcon from '../assets/images/back.svg';
import Footer from '../components/footer.astro'

interface Link {
  name: string;
  link: string;
  banner?: string;
}

import { getCollection } from 'astro:content';

const linksEntry = await getCollection('links');
const links: Link[] = linksEntry.flatMap(entry => entry.data);

const linkRows: (Link[])[] = [];
let i = 0, odd = true;
while (i < links.length) {
  const size = odd ? 4 : 3;
  linkRows.push(links.slice(i, i + size));
  i += size;
  odd = !odd;
}

const navLinks = [
  { href: '/about/', title: 'About', description: '自己紹介というやつです' },
  { href: '/content/', title: 'Content', description: '作ったものたちがいます' },
  { href: '/blog/', title: 'Blog', description: '文章が置いてあります' },
] as const;

const ogUrl = new URL(Astro.url.pathname, Astro.site).href;
---
<Layout ogUrl={ogUrl} ogDescription="coiluckの個人サイト">
  <div class="container">
    <Topbar />

    <main class="top-main-container">

      <IconImage
        imageSrc="/images/icon_base.avif"
        hoverImageSrc="/images/icon_hover.avif"
        size={320}
      />

      <div class="top-description-container">
        <h2>ひとつひとつでいいからね</h2>
        <p>One step at a time.</p>
      </div>

      <div class="top-link-container">
        {navLinks.map((item) => (
          <a href={item.href} class="top-link-box">
            <div class="top-link-text-container">
              <p>{item.title}</p>
              <span>{item.description}</span>
            </div>
            <div class="top-link-icon-container">
              <div class="top-link-icon">
                <div class="circle-button">
                  <Image src={backIcon} alt="" />
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>

      {linkRows.length !== 0 &&
        <div class="top-banner-container">
          <div class="top-banner-title"><span></span><p>すてきなサイトたち</p><span></span></div>
          <div class="top-banner-content" id="top-banner-content">
            {linkRows.map((row) => (
              <div class="top-banner-row">
                {row.map((linkItem) => (
                  <a href={linkItem.link} title={linkItem.name} target="_blank" rel="noopener noreferrer">
                    {linkItem.banner ? (
                      <img src={linkItem.banner} alt={linkItem.name} />
                    ) : (
                      <span>{linkItem.name}</span>
                    )}
                  </a>
                ))}
              </div>
            ))}
          </div>
          <p class="top-banner-foot">当サイトのバナーは<a href="/about/#サイトバナー">こちら</a></p>
        </div>
      }

      <div id="counter" class="loading"></div>
    </main>

    <Footer />
  </div>

  <style>
    .container {
      display: flex;
      flex-direction: column;
      align-items: center;
      height: 100dvh;
      padding-top: 5rem; /* top-bar の分 */
      overflow-y: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
      &::-webkit-scrollbar {
        display: none;
      }
    }
    .top-main-container {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
      width: 100%;
      padding: 2rem;
    }
    @media (min-width: 768px) {
      .top-main-container {
        width: 80%;
      }
    }

    .top-description-container {
      width: 100%;
      margin: 0 auto;
      text-align: center;
    }

    /* navi */
    .top-link-container {
      display: grid;
      grid-template-columns: 1fr;
      gap: .75rem;
      width: 100%;
    }
    @media (min-width: 768px) {
      .top-link-container {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    .top-link-container a.top-link-box {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 1rem;
      position: relative;
      width: 100%;
      padding: 1rem;
      text-decoration: none;
      color: var(--text);
      background-color: rgb(from var(--bg-mild) r g b / 0.5);
      backdrop-filter: blur(1px);
      border-radius: .5rem;
      overflow: hidden;
    }

    .top-link-text-container p {
      width: fit-content;
      background: linear-gradient(currentcolor, currentcolor) left bottom / 100% 2px no-repeat,
        linear-gradient(var(--accent), var(--accent)) right 60% / 0 .8rem no-repeat;
      transition: background-size .4s cubic-bezier(0.215, 0.61, 0.355, 1);
    }
    @media (hover: hover) {
      .top-link-container a.top-link-box:hover .top-link-text-container p {
        background-position: right bottom, left 60%;
        background-size: 0 2px, 100% .8rem;
      }
    }
    .top-link-text-container span {
      font-size: .8rem;
      opacity: .7;
    }
    .top-link-box .top-link-icon-container {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .top-link-box .top-link-icon {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .top-link-container .circle-button {
      position: relative;
      width: 2rem;
      height: 2rem;
      background-color: var(--accent);
      border-radius: 50%;
      display: flex;
      justify-content: center;
      align-items: center;
      flex-shrink: 0;
    }

    .top-link-container .circle-button img {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%) rotate(180deg); /* backをnext方向に */
      width: 60%;
      height: 60%;
      object-fit: contain;
      overflow: hidden;
    }

    @media (hover: hover) {
      .top-link-container a.top-link-box:hover .circle-button img {
        animation: linkArrowAnimation 0.9s ease-in-out infinite;
      }
    }

    @keyframes linkArrowAnimation {
      0%   { transform: translate(-50%, -50%) rotate(180deg) translateX(0);     opacity: 1; }
      20%  { transform: translate(-50%, -50%) rotate(180deg) translateX(-150%); opacity: 0; }
      40%  { transform: translate(-50%, -50%) rotate(180deg) translateX(150%);  opacity: 0; }
      66%  { transform: translate(-50%, -50%) rotate(180deg) translateX(0);     opacity: 1; }
      100% { transform: translate(-50%, -50%) rotate(180deg) translateX(0);     opacity: 1; }
    }

    /* 相互リンク */
    .top-banner-container {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      width: 100%;
    }
    .top-banner-container .top-banner-title {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
    }
    .top-banner-container .top-banner-title span {
      height: 1px;
      background-color: var(--text);
    }
    .top-banner-container .top-banner-title p {
      font-size: 1.2rem;
    }
    .top-banner-container .top-banner-content {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    :global(.top-banner-row) {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 1rem;
      width: 100%;
    }
    :global(.top-banner-row a) {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 175px;
      height: 35px;
      background-color: var(--text);
      text-decoration: none;
    }
    :global(.top-banner-row a img) {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    :global(.top-banner-row a span) {
      width: 100%;
      padding: .25rem .5rem;
      white-space: nowrap;
      overflow: hidden;
      text-align: center;
      text-overflow: ellipsis;
      font-size: 1rem;
      color: var(--bg);
    }
    .top-banner-foot {
      text-align: center;
      font-size: .8rem;
    }
    .top-banner-foot a {
      color: var(--link);
    }

    /* アクセスカウンタ */
    #counter {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      padding: 1rem 0;
      border-top: 1px dashed var(--text);
      border-bottom: 1px dashed var(--text);
      max-height: 100vh; /* 実際より大きければいい */
      transition: all .3s ease-out;
    }
    #counter.loading {
      border: none; /* accessの反映前 */
      max-height: 0;
    }
  </style>

  <script>
    import { initializeApp } from 'firebase/app';
    import { getFirestore, doc, updateDoc, increment, getDoc } from 'firebase/firestore';

    // access counter
    (async () => {
      const app = initializeApp({
        apiKey: import.meta.env.PUBLIC_FIREBASE_API_KEY,
        authDomain: import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
        projectId: import.meta.env.PUBLIC_FIREBASE_PROJECT_ID,
        storageBucket: import.meta.env.PUBLIC_FIREBASE_STORAGE_BUCKET,
        messagingSenderId: import.meta.env.PUBLIC_FIREBASE_MESSAGING_SENDER_ID,
        appId: import.meta.env.PUBLIC_FIREBASE_APP_ID,
        measurementId: import.meta.env.PUBLIC_FIREBASE_MEASUREMENT_ID,
      });

      try {
        const db = getFirestore(app);
        const ref = doc(db, 'accessTimes', 'zFZtsCWbvhtHNrLXHuqs');

        // +1 して取得
        await updateDoc(ref, { count: increment(1) });
        const snap = await getDoc(ref);
        if (!snap.exists()) return;
        const count = snap.data().count as number;

        // 桁ごとに画像を差し込む
        const el = document.getElementById('counter');
        if (!el) return;

        const imageTypeArray = ["blue", "colorful"]
        const randomImageType = imageTypeArray[Math.floor(Math.random() * imageTypeArray.length)];

        el.innerHTML = String(count)
          .split('')
          .map(d => `<img src="/images/${randomImageType}/${d}.png" alt="${d}">`)
          .join('');

        el.classList.remove('loading');
      } catch (e) {
        console.error(`faild to connect db of access counter: ${e}`)

        // 非表示（破線があるので）
        const counter = document.getElementById('counter')

        if (counter) {
          counter.style.display = 'none'
          counter.classList.remove('loading')
        }
      }
    })();

    // banner
    const container = document.getElementById('top-banner-content');

    if (container) {
      const rootFontSize = parseFloat(getComputedStyle(document.documentElement).fontSize);
      const GAP = 1 * rootFontSize;
      const ITEM = 175;

      const ro = new ResizeObserver(entries => {
        const width = entries[0].contentRect.width;
        const cols = Math.max(1, Math.floor((width + GAP) / (ITEM + GAP)));

        const anchors = [...container.querySelectorAll('a')];
        container.innerHTML = '';

        let i = 0, odd = true;
        while (i < anchors.length) {
          const size = odd ? cols : Math.max(1, cols - 1);
          const row = document.createElement('div');
          row.className = 'top-banner-row';
          anchors.slice(i, i + size).forEach(a => row.appendChild(a));
          container.appendChild(row);
          i += size;
          odd = !odd;
        }
      });

      ro.observe(container);
    }
  </script>
</Layout>