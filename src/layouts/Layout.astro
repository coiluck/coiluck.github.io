---
const siteTitle = import.meta.env.SITE_TITLE;

interface Props {
  pageTitle?: string; // top のみなし
  ogUrl: string;
  ogDescription?: string;
}

const { pageTitle, ogUrl, ogDescription } = Astro.props;
const siteUrl = Astro.site ? Astro.site.toString().replace(/\/$/, '') : 'https://coiluck.moe';
const OGImage = new URL("/images/ogp.png", siteUrl).toString();
---
<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={ogDescription} />
    <link rel="icon" href="/images/favicon.ico" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <title>{siteTitle}{pageTitle && ` | ${pageTitle}`}</title>
    <meta property="og:title" content={pageTitle ? `${siteTitle} | ${pageTitle}` : siteTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={ogUrl || Astro.url.toString()} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={OGImage} />
    <meta property="og:site_name" content={siteTitle} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={siteTitle} />

    <style>
      @font-face {
        font-family: 'mamelon3.5';
        src: url('/Mamelon-3.5HiRegular.woff2') format('woff2');
        font-display: swap;
      }
      :root {
        --primary: #1a2a4f;
        --accent: #ff7f7e;
        --text-dark: #0a0f1e;
        /* ここから変わる部分 */
        --bg: #fff3f1;
        --text: #0a0f1e;
        --bg-mild: #d1bdbd;
      }
      :root[data-theme="dark"] {
        --bg: #0a0f1e;
        --text: #fff3f1;
        --bg-mild: #2a3a5f;
      }
      html, body {
        margin: 0;
        padding: 0;
        width: 100%;
        color: var(--text);
        line-height: 1.6;
        background-color: var(--bg);
      }
      * {
        font-family: 'mamelon3.5', 'Noto Sans JP', sans-serif;
      }
      html {
        min-height: 100vh;
      }
      body {
        background-color: var(--bg);
        transition: all 0.5s;
      }
      body.loading {
        transition: none !important;
      }
    </style>
  </head>
  <body class="loading">
    <script is:inline>
      function setTheme () {
        const storedTheme = localStorage.getItem('theme');

        if (storedTheme) {
          document.documentElement.setAttribute('data-theme', storedTheme);
        } else {
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          console.log(prefersDark)
          document.documentElement.setAttribute('data-theme', prefersDark ? 'dark' : 'light');
        }
      };
      setTheme();
    </script>

    <slot />

    <script is:inline>
      window.onload = () => {
        document.body.classList.remove('loading');
      };
    </script>
  </body>
</html>