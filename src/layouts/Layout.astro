---
import Live2D from '../components/Live2D.astro';

const siteTitle = import.meta.env.SITE_TITLE;

interface Props {
  pageTitle?: string; // top のみなし
  ogUrl: string;
  ogDescription?: string;
  isBlog?: boolean;
}

const { pageTitle, ogUrl, ogDescription, isBlog } = Astro.props;
const siteUrl = Astro.site ? Astro.site.toString().replace(/\/$/, '') : 'https://coiluck.moe';
const OGImage = new URL("/images/ogp.png", siteUrl).toString();
---
<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={ogDescription} />
    <link rel="icon" href="/images/favicon.ico" />
    {isBlog && (
      <link rel="alternate" type="application/rss+xml" title="革命学舎 | Blog" href="/rss.xml" />
    )}
    <link rel="sitemap" href="/sitemap-index.xml" />
    <title>{siteTitle}{pageTitle && ` | ${pageTitle}`}</title>
    <meta property="og:title" content={pageTitle ?? siteTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={ogUrl || Astro.url.toString()} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={OGImage} />
    <meta property="og:site_name" content={siteTitle} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={siteTitle} />

    <style>
      @font-face {
        font-family: 'mamelon3.5';
        src: url('/Mamelon-3.5HiRegular.woff2') format('woff2');
        font-display: swap;
      }
      :root {
        --primary: #1a2a4f;
        --text-dark: #0a0f1e;
        /* ここから変わる部分 */
        --accent: #ff7f7e;
        --bg: #fff3f1;
        --text: #0a0f1e;
        --bg-mild: #fcd1d1;
        --link: #0066cc;
      }
      :root[data-theme="dark"] {
        --accent: #ff2a3d;
        --bg: #0a0f1e;
        --text: #fff3f1;
        --bg-mild: #2a3a5f;
        --link: #6088C6;
      }
      html, body {
        margin: 0;
        padding: 0;
        width: 100%;
        color: var(--text);
        line-height: 1.6;
        background-color: var(--bg);
      }
      html {
        height: 100dvh;
      }
      body {
        background-color: var(--bg);
        background-image: radial-gradient(rgb(from var(--text) r g b / .5) 1px, transparent 1px);
        background-size: 20px 20px;
        transition: all 0.5s;
      }
      body.loading {
        transition: none !important;
      }
    </style>
    <style is:global>
      * {
        margin: 0;
        padding: 0;
        font-family: 'mamelon3.5', 'Noto Sans JP', sans-serif;
        box-sizing: border-box;
        -webkit-tap-highlight-color: transparent;
      }
      img:not(.free) {
        user-select: none;
        -webkit-user-select: none;
        -moz-user-select: none;
        -ms-user-select: none;
        -webkit-user-drag: none;
        -khtml-user-drag: none;
        -moz-user-drag: none;
        -o-user-drag: none;
      }
      a {
        text-underline-offset: .2rem;
      }
    </style>
  </head>
  <body class="loading">
    <script is:inline>
      function setTheme () {
        const storedTheme = localStorage.getItem('theme');

        if (storedTheme) {
          document.documentElement.setAttribute('data-theme', storedTheme);
        } else {
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          document.documentElement.setAttribute('data-theme', prefersDark ? 'dark' : 'light');
        }
      };
      setTheme();

      // コナミの隠しカラー
      const konamiPalette = {
        '--accent': '#4d82f5',
        '--bg': '#ffb868',
        '--text': '#2a1215',
        '--bg-mild': '#ff8802',
        '--link': '#0066cc',
      };
      window.applyKonamiColors = () => {
        const root = document.documentElement;
        for (const name in konamiPalette) root.style.setProperty(name, konamiPalette[name]);
      };
      window.clearKonamiColors = () => {
        const root = document.documentElement;
        for (const name in konamiPalette) root.style.removeProperty(name);
        sessionStorage.removeItem('konami');
      };
      // ページをまたいでも残す
      if (sessionStorage.getItem('konami') === 'on') {
        window.applyKonamiColors();
      }
    </script>

    <slot />

    <Live2D />

    <script is:inline>
      window.onload = () => {
        document.body.classList.remove('loading');
      };
    </script>

    <script is:inline>
      (() => {
        const sequence = [
          'ArrowUp', 'ArrowUp', 'ArrowDown', 'ArrowDown',
          'ArrowLeft', 'ArrowRight', 'ArrowLeft', 'ArrowRight',
          'b', 'a'
        ];
        let position = 0;

        document.addEventListener('keydown', (e) => {
          const key = e.key.length === 1 ? e.key.toLowerCase() : e.key;
          if (key === sequence[position]) {
            position++;
            if (position === sequence.length) {
              // 全部あった
              position = 0;
              document.dispatchEvent(new CustomEvent('konami'));
            }
          } else {
            // やり直し
            position = 0;
          }
        });
      })();

      document.addEventListener('konami', () => {
        // カラーチェンジ ＋ ページをまたいでも残すよう保存
        window.applyKonamiColors();
        sessionStorage.setItem('konami', 'on');
      })
    </script>
  </body>
</html>