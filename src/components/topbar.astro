---
import sunImage from '../assets/images/sun.svg';
import moonImage from '../assets/images/moon.svg';

const siteTitle = import.meta.env.SITE_TITLE;
---
<div class="top-bar">
  <div class="top-bar-svg-wrapper">
    <svg
      class="top-bar-svg"
      viewBox="0 0 720 240"
      xmlns="http://www.w3.org/2000/svg"
      preserveAspectRatio="xMinYMin meet"
    >
      <path
        d="M 0,0 V 240 H 410 L 480,160 H 580 L 720,0 Z"
        fill="var(--bg)"
        stroke="none"
      />
      <path
        id="top-bar-line"
        d="M 0,239 H 410 L 480,160 H 580 L 720,0"
        fill="none"
        stroke="var(--text)"
        stroke-width="5"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>

    {/* site name */}
    <div class="svg-content">
      <a href="/" class="custom-link site-name">
        {siteTitle}
        <span class="site-name-inner"></span>
      </a>
    </div>
  </div>

  {/* 右側のテキスト */}
  <div class="top-bar-right">
    <div class="top-bar-toggle">
      <span
        class="icon sun-icon"
        style={`--icon-url: url(${sunImage.src})`}
        aria-label="太陽のアイコン"
        role="img"
      ></span>
      <span
        class="icon moon-icon"
        style={`--icon-url: url(${moonImage.src})`}
        aria-label="月のアイコン"
        role="img"
      ></span>
    </div>
  </div>
</div>

<style>
  .top-bar {
    position: absolute;
    top: 0;
    left: 0;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    width: 100%;
    height: 3.5rem;
    background-color: var(--bg);
    z-index: 1000;
    overflow: visible;
  }

  /* TopBar下端のライン */
  .top-bar::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 1.5px;
    background-color: var(--text);
    z-index: -1;
  }

  /* SVG: TopBarより下にはみ出す */
  .top-bar-svg-wrapper {
    position: relative;
    height: 6rem;
    flex-shrink: 0;
  }

  .top-bar-svg {
    display: block;
    height: 100%;
    width: auto;
  }

  #top-bar-line {
    stroke-dasharray: var(--path-length, 1200);
    stroke-dashoffset: var(--path-length, 1200);
    animation: draw-line 1s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }
  @keyframes draw-line {
    from { stroke-dashoffset: var(--path-length); }
    to   { stroke-dashoffset: 0; }
  }

  /* SVG内に配置するコンテンツ */
  .svg-content {
    position: absolute;
    top: 0;
    left: 0;
    /* SVGの「平らな上部分」= viewBox 0〜410 / 720 ≒ 56.94% の中央に配置 */
    width: 56.94%;
    height: 6rem; /* svgと揃える */
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: auto;
  }

  @media (max-width: 768px) {
    .top-bar-svg-wrapper {
      height: 4.5rem;
    }
    .svg-content {
      height: 4.5rem;
    }
  }

  .site-name {
    position: relative;
    padding: .5rem 1rem;
    white-space: nowrap;
    color: var(--text);
    text-decoration: none;
    transition: all .3s ease;
  }
  /* 上線 */
  .site-name::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 0;
    height: 1px;
    background-color: var(--text);
    transition: width 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  /* 下線 */
  .site-name::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--text);
    transition: width 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  /* 左縦線 */
  .site-name-inner::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 1px;
    height: 0;
    background-color: var(--text);
    transition: height 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  /* 右縦線 */
  .site-name-inner::after {
    content: '';
    position: absolute;
    bottom: 0;
    right: 0;
    width: 1px;
    height: 0;
    background-color: var(--text);
    transition: height 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @media (hover: hover) {
    .site-name:hover::before {
      width: 100%;
    }
    .site-name:hover::after {
      width: 100%;
    }
    .site-name:hover .site-name-inner::before {
      height: 100%;
    }
    .site-name:hover .site-name-inner::after {
      height: 100%;
    }
  }

  .top-bar-right {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    height: 3.5rem;
    padding-right: 2rem;
  }


  /* mode toggle */
  .top-bar-toggle {
    position: relative;
    height: 100%;
    width: 24px;
    flex-shrink: 0;
    cursor: pointer;
  }
  .top-bar-toggle .icon {
    position: absolute;
    top: 50%;
    width: 24px;
    height: 24px;
    transform: translateY(-50%);
    background-color: var(--text);
    mask-image: var(--icon-url);
    mask-repeat: no-repeat;
    mask-position: center;
    mask-size: contain;
    user-select: none;
    -webkit-user-select: none;
    transition: all 0.3s ease;
  }
  @media (hover: hover) {
    .top-bar-toggle:hover .icon {
      background-color: var(--accent);
    }
  }

  .sun-icon { opacity: 1; }
  .moon-icon { opacity: 0; }

  :global([data-theme="dark"]) .sun-icon { opacity: 0; }
  :global([data-theme="dark"]) .moon-icon { opacity: 1; }
</style>
<script>
  declare global {
    interface Window {
      clearKonamiColors?: () => void;
    }
  }

  function toggleTheme() {
    const currentTheme = document.documentElement.getAttribute('data-theme');
    const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', newTheme);
    localStorage.setItem('theme', newTheme);
    // コナミの隠しカラーを解除して通常テーマに戻す
    window.clearKonamiColors?.();
  }
  document.querySelectorAll('.top-bar-toggle').forEach((el) => {
    el.addEventListener('click', toggleTheme);
  });

  // svgの線
  const line = document.querySelector<SVGPathElement>('#top-bar-line');
  if (line) {
    const length = line.getTotalLength();
    line.style.setProperty('--path-length', String(length));
  }

  export {};
</script>