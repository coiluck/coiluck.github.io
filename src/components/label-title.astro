---
interface Props {
  text: string;
  headStep: 1 | 2 | 3;
}
const { text, headStep = 1 } = Astro.props

let labelClass = '';
switch (headStep) {
  case 1:
    labelClass = 'head-label label-first';
    break;
  case 2:
    labelClass = 'head-label label-second';
    break;
  case 3:
    labelClass = 'head-label label-third';
    break;
}
---
<div class={labelClass} id={text}>{text}</div>

<style>
  .head-label.label-first {
    position: relative;
    padding-left: 1rem;
    padding-bottom: 0.5rem;
    margin: 10px 0;
    font-size: 1.1rem;
    font-weight: bold;
  }
  .head-label.label-first::before {
    content: '';
    position: absolute;
    inset: 0;
    mask-image: url("/images/h2.svg");
    mask-repeat: no-repeat;
    mask-size: auto 100%;
    mask-position: left center;
    background-color: var(--accent);
    pointer-events: none;
    clip-path: inset(0 100% 100% 0);
  }
  /* アニメーション */
  .head-label.label-first.is-visible::before {
    animation: label-first-reveal 1.2s ease-in-out forwards;
  }
  @keyframes label-first-reveal {
    0% {
      clip-path: inset(0 100% 100% 0);
    }
    35% {
      clip-path: inset(0 calc(100% - 15px) 0 0);
    }
    100% {
      clip-path: inset(0 0 0 0);
    }
  }

  .head-label.label-second {
    padding: 5px 10px;
    margin: 10px 0;
    color: var(--text);
    font-size: 1rem;
    font-weight: bold;
    border-left: 4px solid var(--accent);
  }
  /* アニメーション */
  .head-label.label-second.is-visible {
    animation: fadeIn 0.8s ease-in-out;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(5px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .head-label.label-third {
    position: relative;
    width: fit-content;
    padding-left: 1rem;
    margin: 5px 0;
    color: var(--text);
    font-size: 1rem;
    font-weight: bold;
  }
  .head-label.label-third::before {
    content: '・';
    position: absolute;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
    font-size: 1rem;
    color: var(--accent);
  }
  .head-label.label-third::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--accent);
    transition: width 0.8s ease-in-out;
  }
  /* アニメーション */
  .head-label.label-third.is-visible::after {
    width: 100%;
  }

  @media (prefers-reduced-motion: reduce) {
    .head-label.label-first::before {
      animation: none;
      clip-path: inset(0 0 0 0);
    }
    .head-label.label-second {
      animation: none;
    }
    .head-label.label-third::after {
      width: 100%;
      transition: none;
      animation: none;
    }
  }
</style>
<script>
  const oneOffObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        oneOffObserver.unobserve(entry.target);
      }
    });
  }, {
    threshold: 0.2,
  });

  const eternalObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
      } else {
        entry.target.classList.remove('is-visible');
      }
    });
  }, {
    threshold: 0.2,
  });

  document.querySelectorAll('.head-label').forEach((el) => {
    if (el.classList.contains('label-first')) {
      eternalObserver.observe(el);
    } else {
      oneOffObserver.observe(el);
    }
  })
</script>